{
  "manual": "Manual de Integração do PNCP v. 2.5",
  "baseUrl": "https://pncp.gov.br/api/pncp",
  "endpoints": {
    "contratacao": "/v1/orgaos/{cnpj}/compras/{ano}/{sequencial}",
    "itens": "/v1/orgaos/{cnpj}/compras/{ano}/{sequencial}/itens",
    "resultados": "/v1/orgaos/{cnpj}/compras/{ano}/{sequencial}/itens/{numeroItem}/resultados",
    "historico": "/v1/orgaos/{cnpj}/compras/{ano}/{sequencial}/historico"
  },
  "referenciasCanonicas": {
    "manual": "docs/pncp_v2.5/manual/manual_integracao_pncp_v2.5.html",
    "openapi": "docs/pncp_v2.5/openapi/api-docs.json",
    "operacoes": {
      "contratacao": "Manual integral: Consultar uma Contratação",
      "itens": "pesquisarCompraItem",
      "resultados": "recuperarResultados",
      "historico": "consultarCompra"
    }
  },
  "parametros": [
    "cnpj",
    "ano",
    "sequencial",
    "numeroItem",
    "pagina",
    "tamanhoPagina"
  ],
  "camposEvento": [
    "dataResultado",
    "dataInclusao",
    "dataAtualizacao",
    "dataCancelamento",
    "numeroItem",
    "sequencialResultado",
    "niFornecedor",
    "nomeRazaoSocialFornecedor",
    "quantidadeHomologada",
    "valorUnitarioHomologado",
    "valorTotalHomologado",
    "situacaoCompraItemResultadoId",
    "situacaoCompraItemResultadoNome"
  ],
  "camposItem": [
    "numeroItem",
    "descricao",
    "materialOuServico",
    "materialOuServicoNome",
    "valorUnitarioEstimado",
    "valorTotal",
    "quantidade",
    "unidadeMedida",
    "itemCategoriaId",
    "itemCategoriaNome",
    "situacaoCompraItem",
    "situacaoCompraItemNome",
    "dataInclusao",
    "dataAtualizacao",
    "temResultado",
    "ncmNbsCodigo",
    "ncmNbsDescricao",
    "catalogo",
    "categoriaItemCatalogo",
    "catalogoCodigoItem",
    "informacaoComplementar"
  ],
  "camposHistorico": [
    "compraOrgaoCnpj",
    "compraAno",
    "compraSequencial",
    "logManutencaoDataInclusao",
    "tipoLogManutencao",
    "tipoLogManutencaoNome",
    "categoriaLogManutencao",
    "categoriaLogManutencaoNome",
    "itemResultadoNumero",
    "itemResultadoSequencial",
    "usuarioNome",
    "justificativa"
  ],
  "dominiosHistorico": {
    "tipoLogManutencaoInclusao": 0,
    "categoriaLogManutencaoResultadoItem": 5
  },
  "restricao": "O Manual 2.5 não define consulta nacional por dataResultado; os endpoints exigem cnpj, ano e sequencial."
}
