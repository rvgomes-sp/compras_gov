{
  "schema": "event_data_map",
  "version": "2.0.0",
  "project": "GSB Monitor V2",
  "principle": "Cada evento possui fontes, campos mínimos, evidências, regras de valor e exigências próprias. O motor pode começar por qualquer evento sem quebrar a matriz completa.",
  "database_import_now": false,
  "price_dependency": false,
  "selected_start_event": "EVT-007",
  "source_keys": {
    "pca_items": "Itens do Plano de Contratações / PCA / PGC",
    "procurement_publication": "Contratações publicadas",
    "procurement_documents": "Documentos da contratação",
    "proposal_window": "Janela de recebimento de propostas",
    "session_documents": "Atas e documentos de sessão",
    "item_results": "Resultados de item / fornecedor / valor",
    "procurement_history": "Histórico da contratação",
    "contract_lookup": "Consulta de contratos vinculados à contratação",
    "contracts": "Contratos e empenhos com força contratual",
    "contract_documents": "Documentos do contrato",
    "contract_terms": "Termos aditivos, apostilas e rescisões",
    "contract_history": "Histórico do contrato",
    "text_reader": "Motor externo de leitura documental",
    "catalog_material": "Catálogo oficial de materiais observado",
    "catalog_service": "Catálogo oficial de serviços observado"
  },
  "events": {
    "EVT-001": {
      "name": "Planejamento / PCA / PGC",
      "primary_sources": ["pca_items", "catalog_material", "catalog_service"],
      "minimum_fields": ["orgao_cnpj", "orgao_nome", "ano_pca", "item_descricao", "classificacao_catalogo", "pdm_codigo", "pdm_descricao", "valor_planejado_pca", "data_desejada"],
      "documents_expected": [],
      "text_reader": "none",
      "value_policy": ["valor_planejado_pca"],
      "can_generate_opportunity": false,
      "purpose": "Inteligência antecipada e mapa de demanda futura.",
      "future_tables": ["procurement_case", "procurement_item", "catalog_observed"],
      "next_events": ["EVT-002"]
    },
    "EVT-002": {
      "name": "Publicação / Edital",
      "primary_sources": ["procurement_publication", "procurement_documents", "catalog_material", "catalog_service"],
      "minimum_fields": ["numero_controle_pncp", "orgao_cnpj", "orgao_nome", "modalidade", "categoria", "objeto", "valor_estimado_contratacao", "data_publicacao", "data_abertura_proposta", "data_encerramento_proposta"],
      "documents_expected": ["edital", "termo_referencia", "minuta_contrato"],
      "text_reader": "optional",
      "text_reader_purpose": "Identificar cláusula de garantia, prazo de apresentação, percentual, modalidade aceita e exigências de cobertura.",
      "value_policy": ["valor_estimado_contratacao"],
      "can_generate_opportunity": true,
      "purpose": "Antecipação comercial e análise de edital.",
      "future_tables": ["procurement_case", "procurement_item", "event_document", "document_extraction"],
      "next_events": ["EVT-003", "EVT-004", "EVT-005"]
    },
    "EVT-003": {
      "name": "Propostas abertas",
      "primary_sources": ["proposal_window", "procurement_publication", "procurement_documents"],
      "minimum_fields": ["numero_controle_pncp", "orgao_cnpj", "objeto", "modalidade", "data_abertura_proposta", "data_encerramento_proposta", "valor_estimado_contratacao"],
      "documents_expected": ["edital", "termo_referencia", "minuta_contrato"],
      "text_reader": "optional",
      "value_policy": ["valor_estimado_contratacao"],
      "can_generate_opportunity": true,
      "purpose": "Preparação antes da sessão e mapeamento de prováveis participantes.",
      "future_tables": ["case_event", "event_document"],
      "next_events": ["EVT-004", "EVT-005"]
    },
    "EVT-004": {
      "name": "Sessão",
      "primary_sources": ["session_documents", "procurement_history"],
      "minimum_fields": ["numero_controle_pncp", "data_evento", "situacao", "documento_referencia"],
      "documents_expected": ["ata_sessao"],
      "text_reader": "optional",
      "value_policy": ["valor_estimado_contratacao", "valor_item"],
      "can_generate_opportunity": true,
      "purpose": "Monitorar disputa, habilitação e classificação preliminar.",
      "future_tables": ["case_event", "event_document"],
      "next_events": ["EVT-005", "EVT-006", "EVT-007"]
    },
    "EVT-005": {
      "name": "Julgamento / Resultado preliminar",
      "primary_sources": ["item_results", "procurement_history"],
      "minimum_fields": ["numero_controle_pncp", "item_numero", "fornecedor_nome", "fornecedor_cnpj_raw", "valor_resultado_item", "situacao_item", "data_resultado"],
      "documents_expected": ["ata_julgamento"],
      "text_reader": "optional",
      "value_policy": ["valor_resultado_item", "valor_resultado_fornecedor_agregado"],
      "can_generate_opportunity": true,
      "purpose": "Identificar vencedor provável sem presumir homologação ou contrato.",
      "future_tables": ["procurement_supplier_result", "case_event", "event_value"],
      "next_events": ["EVT-006", "EVT-007"]
    },
    "EVT-006": {
      "name": "Recurso / Contrarrazões / Decisão",
      "primary_sources": ["procurement_history", "procurement_documents"],
      "minimum_fields": ["numero_controle_pncp", "data_evento", "tipo_documento", "descricao_evento"],
      "documents_expected": ["recurso", "contrarrazoes", "decisao_recurso"],
      "text_reader": "optional",
      "text_reader_purpose": "Identificar impacto sobre vencedor, suspensão, anulação, revogação ou alteração de resultado.",
      "value_policy": ["valor_resultado_item", "valor_resultado_fornecedor_agregado"],
      "can_generate_opportunity": true,
      "purpose": "Rota consultiva e acompanhamento de instabilidade do resultado.",
      "future_tables": ["case_event", "event_document", "document_extraction"],
      "next_events": ["EVT-007", "EVT-005"]
    },
    "EVT-007": {
      "name": "Homologação / Adjudicação",
      "operational_priority": 1,
      "primary_sources": ["item_results", "procurement_history"],
      "secondary_sources": ["procurement_documents", "contract_lookup", "catalog_material", "catalog_service"],
      "minimum_fields": ["numero_controle_pncp", "orgao_cnpj", "orgao_nome", "objeto", "categoria", "modalidade", "item_numero", "fornecedor_nome", "fornecedor_cnpj_raw", "valor_resultado_item", "situacao_item", "data_homologacao"],
      "aggregation_fields": ["numero_controle_pncp", "fornecedor_cnpj_raw", "fornecedor_nome", "item_numero", "lote_numero"],
      "derived_fields": ["valor_resultado_fornecedor_agregado", "itens_homologados_count", "contrato_check_status"],
      "documents_expected": ["termo_homologacao", "ata_julgamento", "resultado_final"],
      "text_reader": "optional",
      "text_reader_purpose": "Confirmar se documentos de homologação ou edital mencionam garantia, prazo de apresentação e minuta contratual.",
      "value_policy": ["valor_resultado_fornecedor_agregado"],
      "can_generate_opportunity": true,
      "commercial_window": "principal",
      "purpose": "Principal gatilho para identificar fornecedor vencedor antes do contrato ou imediatamente antes da assinatura.",
      "forbidden": ["nao_presumir_contrato_assinado", "nao_presumir_garantia_sem_edital_ou_minuta", "nao_usar_valor_estimado_como_valor_do_vencedor"],
      "future_tables": ["procurement_case", "procurement_supplier_result", "case_event", "event_value", "event_alert"],
      "next_events": ["EVT-008", "EVT-009", "EVT-006"]
    },
    "EVT-008": {
      "name": "Pré-assinatura",
      "primary_sources": ["item_results", "contract_lookup", "procurement_history"],
      "minimum_fields": ["numero_controle_pncp", "fornecedor_nome", "fornecedor_cnpj_raw", "valor_resultado_fornecedor_agregado", "data_homologacao", "contrato_verificado_ausente", "data_verificacao_contrato"],
      "documents_expected": ["edital", "minuta_contrato"],
      "text_reader": "recommended",
      "text_reader_purpose": "Confirmar cláusula de garantia e prazo provável de apresentação.",
      "value_policy": ["valor_resultado_fornecedor_agregado"],
      "can_generate_opportunity": true,
      "commercial_window": "critica_ate_30_dias",
      "purpose": "Janela crítica de abordagem quando já existe vencedor/homologação e ainda não há contrato localizado.",
      "future_tables": ["case_event", "event_value", "event_alert", "document_extraction"],
      "next_events": ["EVT-009"]
    },
    "EVT-009": {
      "name": "Contrato publicado",
      "primary_sources": ["contracts", "contract_documents"],
      "minimum_fields": ["numero_controle_pncp", "numero_contrato", "fornecedor_nome", "fornecedor_cnpj_raw", "valor_global_contrato", "data_assinatura", "data_publicacao", "vigencia_inicio", "vigencia_fim"],
      "documents_expected": ["contrato", "empenho_com_forca_contratual"],
      "text_reader": "recommended",
      "text_reader_purpose": "Extrair cláusula de garantia, percentual, vigência, prazo de apresentação e obrigação de endosso.",
      "value_policy": ["valor_inicial_contrato", "valor_global_contrato", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "commercial_window": "pos_assinatura_ate_10_dias",
      "purpose": "Validar obrigação de garantia, aderência da apólice e oportunidade de emissão ou revisão.",
      "future_tables": ["procurement_contract", "case_event", "event_document", "document_guarantee_clause"],
      "next_events": ["EVT-010", "EVT-011", "EVT-012", "EVT-013", "EVT-014"]
    },
    "EVT-010": {
      "name": "Execução",
      "primary_sources": ["contracts", "contract_history", "contract_documents"],
      "minimum_fields": ["numero_contrato", "fornecedor_nome", "fornecedor_cnpj_raw", "vigencia_inicio", "vigencia_fim", "valor_global_contrato", "situacao_contrato"],
      "documents_expected": ["medicoes", "ordens_servico", "historico_contrato"],
      "text_reader": "optional",
      "value_policy": ["valor_global_contrato", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "purpose": "Monitoramento de risco, execução, cláusula trabalhista e oportunidades consultivas.",
      "future_tables": ["procurement_contract", "case_event", "event_document"],
      "next_events": ["EVT-011", "EVT-012", "EVT-013", "EVT-014"]
    },
    "EVT-011": {
      "name": "Aditivo",
      "primary_sources": ["contract_terms", "contract_documents", "contract_history"],
      "minimum_fields": ["numero_contrato", "tipo_termo", "numero_termo", "data_assinatura", "objeto_termo"],
      "documents_expected": ["termo_aditivo"],
      "text_reader": "recommended",
      "text_reader_purpose": "Identificar alteração de prazo, valor, escopo, reequilíbrio, acréscimo, supressão e impacto na garantia.",
      "value_policy": ["valor_atualizado_aditivo_apostila", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "purpose": "Endosso, reforço, renovação, substituição ou análise consultiva.",
      "future_tables": ["procurement_contract_term", "case_event", "event_document", "document_extraction"],
      "next_events": ["EVT-010", "EVT-012", "EVT-013", "EVT-014"]
    },
    "EVT-012": {
      "name": "Apostila",
      "primary_sources": ["contract_terms", "contract_documents", "contract_history"],
      "minimum_fields": ["numero_contrato", "tipo_termo", "numero_termo", "data_assinatura", "objeto_termo", "valor_atualizado_aditivo_apostila"],
      "documents_expected": ["termo_apostilamento"],
      "text_reader": "recommended",
      "text_reader_purpose": "Identificar reajuste, atualização, valor contratual atualizado e efeito sobre importância segurada.",
      "value_policy": ["valor_atualizado_aditivo_apostila", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "purpose": "Compatibilização de valor e vigência sem presumir acréscimo físico.",
      "future_tables": ["procurement_contract_term", "case_event", "event_document", "document_extraction"],
      "next_events": ["EVT-010", "EVT-011", "EVT-013", "EVT-014"]
    },
    "EVT-013": {
      "name": "Vigência final / Renovação",
      "primary_sources": ["contracts", "contract_terms", "contract_history"],
      "minimum_fields": ["numero_contrato", "fornecedor_nome", "fornecedor_cnpj_raw", "vigencia_fim", "valor_global_contrato", "situacao_contrato"],
      "documents_expected": ["contrato", "termos_prorrogacao"],
      "text_reader": "optional",
      "text_reader_purpose": "Identificar obrigação de manutenção da garantia, prazo adicional e endossos.",
      "value_policy": ["valor_global_contrato", "valor_atualizado_aditivo_apostila", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "purpose": "Renovação, substituição, endosso de prazo e atuação em recusa de seguradora.",
      "future_tables": ["procurement_contract", "case_event", "event_alert"],
      "next_events": ["EVT-011", "EVT-012", "EVT-014"]
    },
    "EVT-014": {
      "name": "Sinistro / Expectativa de sinistro",
      "primary_sources": ["contract_documents", "contract_history", "procurement_documents", "text_reader"],
      "minimum_fields": ["numero_contrato", "fornecedor_nome", "fornecedor_cnpj_raw", "documento_referencia", "data_evento", "descricao_evento"],
      "documents_expected": ["notificacao", "rescisao", "multa", "processo_administrativo", "execucao_garantia"],
      "text_reader": "required",
      "text_reader_purpose": "Separar fato, documento, inferência, inadimplemento, penalidade, expectativa e sinistro formal.",
      "value_policy": ["valor_global_contrato", "valor_documento_assinado"],
      "can_generate_opportunity": true,
      "purpose": "Rota consultiva crítica, regulação, mitigação, recomposição e estratégia técnica.",
      "future_tables": ["case_event", "event_document", "document_extraction", "document_guarantee_clause", "event_alert"],
      "next_events": []
    }
  }
}
